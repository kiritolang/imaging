# Keep line endings sane regardless of a contributor's core.autocrlf setting. Golden test fixtures
# are compared byte-for-byte, so CRLF would break the diffs. Normalize all text to LF in the repo
# and on checkout.
* text=auto eol=lf

# Always-LF, regardless of detection.
*.ki       text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.expected text eol=lf
*.experr   text eol=lf

# Mark binaries so they are never line-ending converted.
*.png    binary
*.jpg    binary
*.gif    binary
*.gz     binary
*.zip    binary
*.mjpeg  binary
*.y4m    binary
